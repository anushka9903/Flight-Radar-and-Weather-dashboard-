# Application
APP_NAME=FlightRadar Intelligence Backend
ENVIRONMENT=development
DEBUG=false
API_PREFIX=/api/v1
ENABLE_LEGACY_UNPREFIXED_ROUTES=true

# Security / JWT
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-char-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Auth user
AUTH_USERNAME=admin
# Generate hash with: make auth-hash
AUTH_PASSWORD_HASH=

# CORS (comma-separated)
# Example: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20

# OpenSky
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
OPENSKY_POLL_INTERVAL=15

# OpenWeather
OPENWEATHER_API_KEY=replace-with-api-key
OPENWEATHER_POLL_INTERVAL=300
OPENWEATHER_CACHE_TTL=600

# Airspace (India default)
AIRSPACE_MIN_LAT=6.0
AIRSPACE_MAX_LAT=38.0
AIRSPACE_MIN_LON=68.0
AIRSPACE_MAX_LON=98.0
WEATHER_GRID_STEP=3

# Conflict engine
CONFLICT_H_SEP_KM=10.0
CONFLICT_V_SEP_FT=1000.0
CONFLICT_LOOKAHEAD_SECONDS=600

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
